Host *.redhat.com
  GSSAPIAuthentication yes
  GSSAPIDelegateCredentials no
  # https://mojo.redhat.com/docs/DOC-1069454 says never delegate credentials

Host podhost
  User vagrant
  IdentityFile ~/vbox/podhost/.vagrant/machines/default/virtualbox/private_key

Host blackbox
  HostName blackbox.local
  Port 2222

Host *
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/id_rsa

