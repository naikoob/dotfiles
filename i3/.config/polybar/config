[color]

bg = #16000000
fg = #FFFFFF
fg-alt = #A9ABB0

acolor = #FFFFFF
curgent = #EF5350
coccupied = #42A5F5

shade1 = #007300
shade2 = #006600
shade3 = #005900
shade4 = #004D00
shade5 = #004000
shade6 = #003300
shade7 = #003300
shade8 = #002600
txt = #2C2C2C

## Material Colors

red = #e53935
pink = #d81b60
purple = #8e24aa
deep-purple = #5e35b1
indigo = #3949ab
blue = #1e88e5
light-blue = #039be5
cyan = #00acc1
teal = #00897b
